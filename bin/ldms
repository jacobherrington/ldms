#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

print_help() {
  cat <<'EOF'
ldms command helper

Usage:
  bin/ldms <command> [args]

Common commands:
  help         Show this help
  quickstart   Print simplest startup flow
  start        Run checks then start local MCP server
  check        Run doctor + smoke
  ui           Start the local LDMS web UI
  test         Run tests
  eval         Run eval gates
  bootstrap    Container-first setup
  global-print Print global MCP config snippet
  global-install Install global MCP config
EOF
}

if [[ $# -eq 0 ]]; then
  print_help
  exit 0
fi

command_name="$1"
shift || true

case "$command_name" in
  help|-h|--help)
    print_help
    ;;
  quickstart)
    exec bundle exec rake quickstart "$@"
    ;;
  start)
    exec bundle exec rake start "$@"
    ;;
  check|doctor)
    exec bundle exec rake check "$@"
    ;;
  global-print)
    exec bundle exec rake global_mcp:print "$@"
    ;;
  global-install)
    exec bundle exec rake global_mcp:install "$@"
    ;;
  *)
    exec bundle exec rake "$command_name" "$@"
    ;;
esac

